 void ContentSerializedNavigationDriver::Sanitize(
     SerializedNavigationEntry* navigation) const {
+  // Astro: Sessions saved with astro:// URLs (e.g. from older versions or sync)
+  // need to be restored as chrome:// so the internal WebUI routing works.
+  // The display layer will convert chrome:// back to astro:// for the user.
+  const auto& virtual_url = navigation->virtual_url();
+  if (virtual_url.SchemeIs(content::kAstroUIScheme)) {
+    GURL::Replacements replacements;
+    replacements.SetSchemeStr(content::kChromeUIScheme);
+    navigation->set_virtual_url(virtual_url.ReplaceComponents(replacements));
+  }
 }
 
