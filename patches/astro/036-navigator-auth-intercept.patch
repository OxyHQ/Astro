 // Returns true on success. Otherwise, if changing params leads the browser
 // into an erroneous state, returns false.
 bool AdjustNavigateParamsForURL(NavigateParams* params) {
+  // Astro: Intercept Oxy auth callbacks (HTTPS redirect from auth.oxy.so)
+  if (oxy::IsOxyAuthCallback(params->url)) {
+    auto callback_params = oxy::ParseOxyAuthCallback(params->url);
+    if (callback_params.is_valid) {
+      Profile* profile = params->initiating_profile;
+      if (profile) {
+        PrefService* prefs = profile->GetPrefs();
+        prefs->SetString("oxy.session_id", callback_params.session_id);
+        prefs->SetString("oxy.user_id", callback_params.user_id);
+        prefs->SetString("oxy.username", callback_params.username);
+        prefs->SetString("oxy.user_avatar", callback_params.avatar_url);
+        prefs->SetString("oxy.token_expiry", callback_params.expires_at);
+        oxy::OxyAuthTokenStore::StoreAccessToken(
+            callback_params.access_token);
+        oxy::OxyAuthTokenStore::StoreRefreshToken(
+            callback_params.refresh_token);
+        LOG(INFO) << "Oxy: Signed in as " << callback_params.username;
+      }
+    }
+    // Redirect to new tab instead of showing the callback URL
+    params->url = GURL("chrome://newtab");
+  }
+
+  // Astro: Rewrite astro:// to chrome:// for navigation
+  if (params->url.SchemeIs("astro")) {
+    GURL::Replacements replacements;
+    replacements.SetSchemeStr(content::kChromeUIScheme);
+    params->url = params->url.ReplaceComponents(replacements);
+  }
+
