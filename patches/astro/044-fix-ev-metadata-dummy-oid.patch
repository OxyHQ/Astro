From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Nate Isern <nate@oxy.so>
Date: Fri, 4 Apr 2026 00:00:00 +0000
Subject: [PATCH] Fix EV metadata dummy OID decode error

The ungoogled Remove-EV-certificates patch uses "0" as a dummy OID,
which is not valid ASN.1 OID format and causes a LOG(ERROR) at startup.
Replace with a valid but unused OID in the IANA private enterprise arc.

--- a/net/cert/ev_root_ca_metadata.cc
+++ b/net/cert/ev_root_ca_metadata.cc
@@ -36,14 +36,13 @@ struct EVMetadata {
   const std::string_view policy_oids[kMaxOIDsPerCA];
 };

 static const EVMetadata kEvRootCaMetadata[] = {
-    // need some dummy thing to make compiler happy, because
-    // arraysize() is implemented as a convoluted template rather than
-    // the traditional sizeof(x)/sizeof(*x)
+    // Dummy entry: EV certificates are disabled in Astro.
+    // Uses a valid OID to avoid decode errors at startup.
     { { { 0xff, 0xff, 0xff, 0xff, 0xff, 0xff, 0xff, 0xff, 0xff, 0xff,
           0xff, 0xff, 0xff, 0xff, 0xff, 0xff, 0xff, 0xff, 0xff, 0xff } },
       {
-        "0",
+        "1.3.6.1.4.1.99999.0",
       }
     }
 };
