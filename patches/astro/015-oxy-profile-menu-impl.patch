+void ProfileMenuView::BuildOxySignInButton() {
+  PrefService* prefs = profile().GetPrefs();
+  std::string oxy_username = prefs->GetString(oxy::kOxyUsername);
+  std::string oxy_user_id = prefs->GetString(oxy::kOxyUserId);
+
+  if (oxy_user_id.empty()) {
+    // Not signed in to Oxy: show "Sign in with Oxy" button.
+    AddFeatureButton(
+        u"Sign in with Oxy",
+        base::BindRepeating(&ProfileMenuView::OnOxySignInButtonClicked,
+                            base::Unretained(this)),
+        vector_icons::kSettingsChromeRefreshIcon);
+  } else {
+    // Signed in to Oxy: show username and sign-out option.
+    std::u16string label =
+        u"Oxy \u00B7 " + base::UTF8ToUTF16(oxy_username);
+    AddFeatureButton(
+        label,
+        base::BindRepeating(&ProfileMenuView::OnOxySignOutButtonClicked,
+                            base::Unretained(this)),
+        vector_icons::kSettingsChromeRefreshIcon);
+  }
+}
+
+void ProfileMenuView::OnOxySignInButtonClicked() {
+  // Build the Oxy auth URL from constants defined in oxy_auth_service.h.
+  GURL auth_url(std::string(oxy::kOxyAuthUrl) + "/login");
+  auth_url = net::AppendQueryParameter(auth_url, "client_id", "astro-browser");
+  auth_url = net::AppendQueryParameter(auth_url, "redirect_uri",
+                                       "astro://auth/callback");
+  auth_url = net::AppendQueryParameter(auth_url, "response_type", "token");
+
+  // Open in a new foreground tab.
+  NavigateParams params(&browser(), auth_url, ui::PAGE_TRANSITION_LINK);
+  params.disposition = WindowOpenDisposition::NEW_FOREGROUND_TAB;
+  Navigate(&params);
+}
+
+void ProfileMenuView::OnOxySignOutButtonClicked() {
+  // Clear stored tokens and user prefs.
+  oxy::OxyAuthTokenStore::ClearTokens();
+  PrefService* prefs = profile().GetPrefs();
+  prefs->ClearPref(oxy::kOxySessionId);
+  prefs->ClearPref(oxy::kOxyUserId);
+  prefs->ClearPref(oxy::kOxyUsername);
+  prefs->ClearPref(oxy::kOxyUserAvatar);
+  prefs->ClearPref(oxy::kOxyTokenExpiry);
+
+  // Close the menu so it rebuilds on next open.
+  GetWidget()->CloseWithReason(views::Widget::ClosedReason::kUnspecified);
+}
